# Copy this file to .env and fill in THIS project's paper account keys.
# .env is already in .gitignore — it will never get committed.
#
# Get these from the Alpaca dashboard: use the account switcher
# (top-left) to select the paper account you opened for ladder-trader
# specifically — NOT the one fpga-tick-engine uses — then generate a
# key pair from that account's own API keys page.

ALPACA_KEY=your_paper_account_key_id_here
ALPACA_SECRET=your_paper_account_secret_here
